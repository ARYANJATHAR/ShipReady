# ─────────────────────────────────────────────────────────────────────
# ShipReady .gitignore
# Next.js monorepo (app/ + engine/)
# ─────────────────────────────────────────────────────────────────────

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# engine (sibling monorepo package)
/engine/dist/
/engine/coverage/

# testing
/coverage
*.lcov

# next.js
/.next/
/out/

# production
/build

# misc — OS noise
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db
ehthumbs_vista.db
*.lnk

# misc — editor / IDE
.vscode/
.idea/
*.swp
*.swo
*~
*.sublime-project
*.sublime-workspace

# debug logs (root)
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log
logs/

# env files — keep .env.example tracked
.env
.env.*
!.env.example
!.env.sample

# vercel
.vercel

# typescript build cache
*.tsbuildinfo
next-env.d.ts

# OS temp / generated
.tmp/
.temp/
.cache/
.eslintcache

.PLAN-PHASE-3.md