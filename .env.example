# AI generation (OpenCode Zen)
# Get an API key at: https://opencode.ai/auth
# Without AI_API_KEY, the app runs in static-template mode.
AI_API_KEY=
AI_BASE_URL=https://opencode.ai/zen/v1
# Default free model. Options: big-pickle, deepseek-v4-flash-free,
# mimo-v2.5-free, north-mini-code-free, nemotron-3-ultra-free
AI_MODEL=big-pickle
